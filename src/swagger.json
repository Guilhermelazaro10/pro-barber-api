{
  "openapi": "3.0.0",
  "info": {
    "title": "ProBarber API",
    "version": "1.0.0",
    "description": "Documentação oficial do ecossistema ProBarber SaaS - Gestão de Barbearias"
  },
  "servers": [
    {
      "url": "http://localhost:3333",
      "description": "Servidor Local"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "tags": [
    { "name": "Auth", "description": "Registo e Acesso de Clientes" },
    { "name": "Gestão", "description": "Configuração de Barbearias e Serviços" },
    { "name": "Agendamentos", "description": "Reserva e Histórico de Clientes" },
    { "name": "Financeiro", "description": "BI e Relatórios de Faturamento" }
  ],
  "paths": {
    "/api/auth/cadastro": {
      "post": {
        "tags": ["Auth"],
        "summary": "Regista um novo cliente",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nome": { "type": "string" },
                  "email": { "type": "string" },
                  "senha": { "type": "string" },
                  "telefone": { "type": "string" },
                  "barbeariaId": { "type": "string", "format": "uuid" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Cliente criado" },
          "400": { "description": "Erro de validação (Zod)" }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Realiza o acesso do cliente",
        "responses": {
          "200": { "description": "Retorna o token JWT" }
        }
      }
    },
    "/api/barbearias/{slug}": {
      "get": {
        "tags": ["Gestão"],
        "summary": "Procura dados públicos de uma barbearia",
        "parameters": [
          { "name": "slug", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Retorna dados da barbearia" }
        }
      }
    },
    "/api/agendamentos/disponibilidade": {
      "get": {
        "tags": ["Agendamentos"],
        "summary": "Lista horários livres de um profissional",
        "parameters": [
          { "name": "profissionalId", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "data", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Lista de horários" }
        }
      }
    },
    "/api/agendamentos": {
      "post": {
        "tags": ["Agendamentos"],
        "summary": "Cria uma nova reserva",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "201": { "description": "Agendamento confirmado" }
        }
      }
    },
    "/api/agendamentos/meus": {
      "get": {
        "tags": ["Agendamentos"],
        "summary": "Histórico de agendamentos do cliente logado",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Retorna o histórico completo" }
        }
      }
    },
    "/api/agendamentos/{id}/concluir": {
      "patch": {
        "tags": ["Agendamentos"],
        "summary": "Marca um serviço como finalizado",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Status atualizado para CONCLUIDO" }
        }
      }
    },
    "/api/financeiro/profissional/{id}": {
      "get": {
        "tags": ["Financeiro"],
        "summary": "Relatório de faturação e comissões",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "inicio", "in": "query", "schema": { "type": "string" } },
          { "name": "fim", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Cálculos financeiros" }
        }
      }
    },
    "/api/financeiro/profissional/{id}/top-servicos": {
      "get": {
        "tags": ["Financeiro"],
        "summary": "Ranking dos 3 serviços mais realizados pelo profissional",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Lista dos serviços campeões de venda" }
        }
      }
    }
  }
}