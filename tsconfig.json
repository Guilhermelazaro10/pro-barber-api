{
  "compilerOptions": {
    /* Configurações de Ambiente */
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["esnext"],
    "skipLibCheck": true,

    /* Suporte a JSON e Módulos */
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    /* Rigor de Tipagem (Nível Sênior) */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true, // Exige 'import type' para tipos, muito bom para performance

    /* Output e Organização */
    "sourceMap": true,
    "outDir": "./dist", // Define onde o código compilado vai ficar
    "declaration": true,
    "declarationMap": true,
    "moduleDetection": "force",
    
    /* Resolução de Tipos Customizados */
    "typeRoots": ["./node_modules/@types", "./src/@types"], // Essencial para o express.d.ts funcionar
    "types": ["node"]
  },
  "include": [
    "src/**/*", 
    "prisma/seed.ts" // Adicionado para você conseguir rodar o seed sem erros de tipo
  ],
  "exclude": ["node_modules", "dist"]
}