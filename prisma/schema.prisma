generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENTE
  ADMIN
}

enum AppointmentStatus {
  PENDENTE
  CONFIRMADO
  CONCLUIDO
  CANCELADO
}

// 1. O Cliente do seu SaaS (A Barbearia)
model Barbearia {
  id              String   @id @default(uuid())
  nomeFantasia    String
  slugUrl         String   @unique // Ex: "navalha-de-ouro"
  telefone        String?
  corPrimaria     String   @default("#000000")
  corSecundaria   String   @default("#FFFFFF")
  logoUrl         String?
  ativo           Boolean  @default(true)
  criadoEm        DateTime @default(now())

  // Relacionamentos
  profissionais   Profissional[]
  servicos        Servico[]
  clientes        Cliente[]
  agendamentos    Agendamento[]

  @@map("barbearias")
}

// 2. Os Barbeiros que trabalham lá
model Profissional {
  id              String   @id @default(uuid())
  nome            String
  comissao        Decimal  @db.Decimal(5, 2)
  
  barbeariaId     String
  barbearia       Barbearia @relation(fields: [barbeariaId], references: [id])
  
  agendamentos    Agendamento[]

  @@map("profissionais")
}

// 3. O que a barbearia vende (Corte, Barba, etc)
model Servico {
  id              String   @id @default(uuid())
  nome            String
  preco           Decimal  @db.Decimal(10, 2)
  duracaoMinutos  Int      
  
  barbeariaId     String
  barbearia       Barbearia @relation(fields: [barbeariaId], references: [id])

  agendamentos    Agendamento[]

  @@map("servicos")
}

// 4. O Cliente final (quem vai cortar o cabelo) - ATUALIZADO PARA LOGIN
model Cliente {
  id              String   @id @default(uuid())
  nome            String
  email           String   @unique // Para o login
  senha           String   // Para o login (armazenar hash)
  telefone        String   
  role            UserRole @default(CLIENTE)
  criadoEm        DateTime @default(now())
  
  barbeariaId     String
  barbearia       Barbearia @relation(fields: [barbeariaId], references: [id])

  agendamentos    Agendamento[]

  @@map("clientes")
}

// 5. O Coração do Sistema
model Agendamento {
  id              String   @id @default(uuid())
  dataHora        DateTime
  status          AppointmentStatus @default(PENDENTE)
  precoCobrado    Decimal  @db.Decimal(10, 2)
  duracaoMinutos  Int
  concluidoEm     DateTime?
  canceladoEm     DateTime?
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt

  barbeariaId     String
  barbearia       Barbearia @relation(fields: [barbeariaId], references: [id])
  
  profissionalId  String
  profissional    Profissional @relation(fields: [profissionalId], references: [id])
  
  clienteId       String
  cliente         Cliente @relation(fields: [clienteId], references: [id])
  
  servicoId       String
  servico         Servico @relation(fields: [servicoId], references: [id])

  @@index([profissionalId, dataHora])
  @@index([barbeariaId, dataHora])
  @@map("agendamentos")
}
